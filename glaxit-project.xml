import React from 'react';

class ErrorBoundary extends React.Component {
    constructor(props) {
        super(props);
        this.state = { error: null };
    }

    static getDerivedStateFromError(error) {
        return { error };
    }

    componentDidCatch(error, info) {
        // Surfaces the real error in the console instead of failing silently
        console.error('Uncaught error in app:', error, info);
    }

    render() {
        if (this.state.error) {
            return (
                <div style={{
                    minHeight: '100vh',
                    display: 'flex',
                    flexDirection: 'column',
                    alignItems: 'center',
                    justifyContent: 'center',
                    padding: '40px',
                    fontFamily: 'system-ui, sans-serif',
                    background: '#f0f2f5',
                    color: '#2d2d2d',
                }}>
                    <h2>Something went wrong</h2>
                    <p style={{ color: '#d63031', maxWidth: 600, textAlign: 'center' }}>
                        {this.state.error.message || String(this.state.error)}
                    </p>
                    <button
                        onClick={() => window.location.assign('/student')}
                        style={{
                            marginTop: 20, padding: '10px 24px', background: '#6c5ce7',
                            color: 'white', border: 'none', borderRadius: 8, cursor: 'pointer',
                        }}
                    >
                        Back to Dashboard
                    </button>
                </div>
            );
        }
        return this.props.children;
    }
}

export default ErrorBoundary;
</file>

<file path="client/src/component/Login.css">
/* ======================================================
   GOOGLE FONT
====================================================== */

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

/* ======================================================
   RESET
====================================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Poppins",sans-serif;
}

html,
body,
#root{
    width:100%;
    min-height:100%;
}

body{
    background:#fafafa;
    overflow-x:hidden;
}

/* ======================================================
   PAGE
====================================================== */

.login-page{

    width:100%;
    min-height:100vh;

    position:relative;

    display:flex;
    justify-content:center;
    align-items:center;

    background:#fafafa;

    padding:30px;

    overflow:hidden;

}

/* ======================================================
   WATERMARK BACKGROUND
====================================================== */

.background-pattern{

    position:fixed;

    top:-20%;
    left:-20%;

    width:140%;
    height:140%;

    display:grid;

    grid-template-columns:repeat(auto-fill,minmax(150px,1fr));

    justify-items:center;

    align-items:center;

    gap:70px;

    transform:rotate(-25deg);

    pointer-events:none;

    z-index:0;

}

/* Every logo container */

.watermark-cell{

    display:flex;

    justify-content:center;

    align-items:center;

}

/* Offset alternate logos for diagonal pattern */

.watermark-cell:nth-child(even){

    transform:translateX(75px);

}

/* Watermark logo */

.watermark-logo{

    width:95px;

    height:auto;

    opacity:.09;

    filter:grayscale(100%);

    object-fit:contain;

    user-select:none;

    pointer-events:none;

}

/* ======================================================
   LOGIN CARD
====================================================== */

.login-card{

    position:relative;

    z-index:100;

    width:100%;

    max-width:1100px;

    min-height:620px;

    display:flex;

    overflow:hidden;

    background:#fff;

    border-radius:22px;

    box-shadow:
        0 20px 60px rgba(0,0,0,.12);

}

/* ======================================================
   LEFT SIDE
====================================================== */

.left-side{

    flex:1;

    position:relative;

    display:flex;

    justify-content:center;

    align-items:center;

    background-size:cover;

    background-position:center;

    overflow:hidden;

}

/* Teal Overlay */

.left-side::before{

    content:"";

    position:absolute;

    inset:0;

    background:rgba(19,168,160,.65);

}

/* Left Content */

.left-content{

    position:relative;

    z-index:5;

    width:80%;

    text-align:center;

    color:#fff;

}

.left-content h2{

    font-size:42px;

    font-weight:600;

    margin-bottom:18px;

}

.left-content p{

    font-size:16px;

    line-height:1.8;

    opacity:.95;


}

/* ======================================================
   CURVED DIVIDER
====================================================== */

.curve{

    position:absolute;

    top:0;

    right:-80px;

    width:170px;

    height:100%;

    background:#fff;

    border-top-left-radius:90px;

    border-bottom-left-radius:90px;

    z-index:10;

}


/* ======================================================
   RIGHT SIDE
====================================================== */

.right-side{

    flex:1;

    display:flex;

    justify-content:center;

    align-items:center;

    padding:60px;

    background:#fff;

}

.login-content{

    width:100%;
    max-width:360px;

}

.login-content h1{

    font-size:42px;

    color:#333;

    text-align:center;

    margin-bottom:10px;

    font-weight:600;

}

.subtitle{

    text-align:center;

    color:#8b8b8b;

    margin-bottom:35px;

    font-size:15px;

}

/* ======================================================
   INPUTS
====================================================== */

.input-box{

    width:100%;

    height:52px;

    border:1px solid #d9d9d9;

    border-radius:50px;

    display:flex;

    align-items:center;

    padding:0 18px;

    margin-bottom:20px;

    transition:.3s;

    background:#fff;

}

.input-box:hover{

    border-color:#19b3aa;

}

.input-box:focus-within{

    border-color:#19b3aa;

    box-shadow:0 0 0 4px rgba(25,179,170,.12);

}

.icon{

    color:#777;

    font-size:16px;

}

.input-box input{

    flex:1;

    margin-left:12px;

    border:none;

    outline:none;

    background:transparent;

    color:#000;

    font-size:15px;

    font-weight:500;

}

.input-box input::placeholder{

    color:#888;

}

/* ======================================================
   OPTIONS
====================================================== */

.login-options{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:30px;

    font-size:14px;

}

.remember{

    display:flex;

    align-items:center;

    gap:8px;

    color:#555;

}

.remember input{

    accent-color:#19b3aa;

}

.login-options a{

    color:#19b3aa;

    text-decoration:none;

    font-weight:500;

}

.login-options a:hover{

    text-decoration:underline;

}

/* ======================================================
   BUTTON
====================================================== */

.login-btn{

    width:100%;

    height:52px;

    border:none;

    border-radius:50px;

    background:#18b4aa;

    color:#fff;

    font-size:17px;

    font-weight:600;

    cursor:pointer;

    transition:.3s;

}

.login-btn:hover{

    background:#13988f;

    transform:translateY(-2px);

    box-shadow:0 12px 25px rgba(24,180,170,.25);

}

/* ======================================================
   SIGNUP
====================================================== */

.signup{

    margin-top:30px;

    text-align:center;

    color:#666;

    font-size:15px;

}

.signup a{

    color:#18b4aa;

    text-decoration:none;

    font-weight:600;

}

.signup a:hover{

    text-decoration:underline;

}

/* ======================================================
   TABLET
====================================================== */

@media(max-width:992px){

.login-card{

flex-direction:column;

max-width:520px;

}

.left-side{

height:280px;

}

.curve{

display:none;

}

.right-side{

padding:40px 30px;

}

.left-content h2{

font-size:34px;

}

.left-content p{

font-size:15px;

}

}

/* ======================================================
   MOBILE
====================================================== */

@media(max-width:576px){

.login-page{

padding:15px;

}

.login-card{

border-radius:16px;

}

.left-side{

height:220px;

}

.right-side{

padding:30px 20px;

}

.login-content{

max-width:100%;

}

.login-content h1{

font-size:32px;

}

.subtitle{

font-size:14px;

margin-bottom:25px;

}

.login-options{

flex-direction:column;

align-items:flex-start;

gap:12px;

}

.input-box{

height:48px;

}

.login-btn{

height:48px;

font-size:16px;

}

.left-content{

width:90%;

}

.left-content h2{

font-size:28px;

}

.left-content p{

font-size:14px;

line-height:1.6;

}

}

/* ======================================================
   LARGE DESKTOP
====================================================== */

@media(min-width:1600px){

.login-card{

max-width:1250px;

}

.login-content{

max-width:420px;

}

.left-content h2{

font-size:48px;

}

}
/* ======================================================
   SUCCESS OVERLAY (shown briefly before redirecting)
====================================================== */

.auth-success-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20, 30, 30, 0.55);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: authFadeIn 0.25s ease;
}

.auth-success-card {
    background: #fff;
    border-radius: 20px;
    padding: 44px 50px;
    max-width: 380px;
    width: 90%;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.25);
    animation: authPopIn 0.3s ease;
}

.auth-success-icon {
    font-size: 52px;
    color: #18b4aa;
    margin-bottom: 16px;
}

.auth-success-card h2 {
    font-size: 20px;
    color: #2d2d2d;
    margin: 0 0 8px 0;
}

.auth-success-card p {
    color: #777;
    font-size: 14px;
    margin: 0;
}

@keyframes authFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes authPopIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
}
</file>

