/* ======================================================
   BASE / LAYOUT
====================================================== */

/* The admin dashboard is a full light-mode app screen, not a page that
   should follow the marketing template's dark-mode / centered-column styles
   from index.css. Pin html/body/#root to the dashboard's own background so
   nothing dark can show through on phones, and stop #root's fixed max-width
   + centering from fighting with this layout.

   color-scheme is the important part on phones: when a phone is in dark
   mode and the page's content is shorter than the viewport (e.g. smaller
   system font making everything more compact), Chrome fills the leftover
   space below the document using the OS/browser's own dark default — not
   this CSS background — unless the page explicitly declares itself light. */
html, body, #root {
    background: #f0f2f5;
    min-height: 100%;
    color-scheme: light;
}
#root {
    width: 100%;
    max-width: 100%;
    border-inline: none;
    display: block;
    text-align: initial;
}

body {
    margin: 0;
    padding: 0;
    background: #f0f2f5;
    font-family: 'Segoe UI', sans-serif;
}

/* 100dvh (not 100vh) so mobile browsers' address bar showing/hiding can't
   leave a gap below the content that exposes the page background. */
.dashboard-container {
    display: flex;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #f0f2f5;
}

