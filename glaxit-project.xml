/* The dashboard is a full light-mode app screen, not a page that should
   follow the marketing template's dark-mode / centered-column styles from
   index.css. Pin html/body/#root to the dashboard's own background so nothing
   dark can show through, and stop #root's fixed max-width + centering from
   fighting with this layout.

   color-scheme is the important part on phones: when a phone is in dark
   mode and the page's content is shorter than the viewport (e.g. smaller
   system font making everything more compact), Chrome fills the leftover
   space below the document using the OS/browser's own dark default — not
   this CSS background — unless the page explicitly declares itself light. */
html, body, #root {
    background: #f0f2f5;
    min-height: 100%;
    color-scheme: light;
}
#root {
    width: 100%;
    max-width: 100%;
    border-inline: none;
    display: block;
    text-align: initial;
}

body { margin: 0; padding: 0; background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
/* 100dvh (not 100vh) so mobile browsers' address bar showing/hiding can't
   leave a gap below the content that exposes the page background. Browsers
   without dvh support just keep the vh value from the line above. */
.dashboard-container { display: flex; height: 100vh; height: 100dvh; overflow: hidden; background: #f0f2f5; }

.sidebar { width: 220px; background: #ffffff; padding: 20px 10px; margin: 10px; border-radius: 20px; border: 1px solid #e0e0e0; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
.sidebar .logo { font-weight: bold; font-size: 1.2rem; margin-bottom: 20px; color: #6c5ce7; padding-left: 15px; }
.sidebar ul { list-style: none; padding: 0; }
.sidebar li { padding: 12px 15px; margin-bottom: 5px; cursor: pointer; border-radius: 10px; color: #555; font-size: 0.9rem; transition: 0.3s; }
.sidebar li.active { background: #6c5ce7; color: white; }
.sidebar li:hover:not(.active) { background: #f4f4f4; }

/* Holds the logo + (phone-only) close button. Always visible so the logo
   shows on desktop too — only .sidebar-close-btn below is phone-only. */
.sidebar-top-row { display: flex; align-items: center; justify-content: space-between; }
.sidebar-close-btn {
    display: none; align-items: center; justify-content: center;
    width: 32px; height: 32px; border: none; border-radius: 50%;
    background: #f4f4f4; color: #555; font-size: 0.9rem; cursor: pointer;
}
.sidebar-backdrop { display: none; }

.main-content { flex: 1; padding: 20px 30px; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 20px; margin: 10px 10px 10px 0; background: #ffffff; }
.top-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
.top-header-left { display: flex; align-items: center; gap: 12px; }
.top-header h1 { color: #2d3436; font-size: 1.5rem; margin: 0; }

/* Hidden on desktop/tablet — only shown on phones, see media query below */
.mobile-menu-btn {
    display: none; align-items: center; justify-content: center;
    width: 38px; height: 38px; flex-shrink: 0;
    border: 1px solid #eee; border-radius: 10px; background: #f9f9f9;
    color: #2d3436; font-size: 1.1rem; cursor: pointer;
}
.mobile-menu-btn:hover { background: #f1f0fb; border-color: #dcd8fb; }

.user-profile-wrap { position: relative; }

.user-profile {
    display: flex; align-items: center; gap: 10px;
    background: #f9f9f9; padding: 6px 14px 6px 6px; border-radius: 50px;
    border: 1px solid #eee; cursor: pointer;
    font-family: inherit; font-size: 0.9rem; color: #2d3436;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
}
.user-profile:hover { background: #f1f0fb; border-color: #dcd8fb; }
.user-profile.open { background: #f1f0fb; border-color: #6c5ce7; box-shadow: 0 0 0 3px rgba(108,92,231,0.12); }

.profile-avatar {
    width: 32px; height: 32px; flex-shrink: 0;
