import React, { useState, useEffect } from 'react';
import { useParams, useNavigate, useLocation } from 'react-router-dom';
import { FaBriefcase, FaClock, FaQuestionCircle, FaTrophy, FaCalendarAlt, FaExclamationTriangle } from 'react-icons/fa';
import "./Quizinstructions.css";

// In production (Vercel) client + API share the same domain, so '/api' just
// works with no config. Locally, set VITE_API_BASE=http://localhost:3000/api
// in client/.env so the dev server (on a different port) still reaches Express.
const API_BASE = import.meta.env.VITE_API_BASE || '/api';

function authHeaders() {
    const token = localStorage.getItem('quiz_token');
    return {
        'Content-Type': 'application/json',
        ...(token ? { Authorization: `Bearer ${token}` } : {}),
    };
}

function formatScheduled(value) {
    if (!value) return null;
    const d = new Date(value);
    if (isNaN(d.getTime())) return null;
    return d.toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' });
}

const QuizInstructions = () => {
    const { id } = useParams();
    const navigate = useNavigate();
    const location = useLocation();
    const [quiz, setQuiz] = useState(null);
    const [loading, setLoading] = useState(true);
    const [loadError, setLoadError] = useState('');

    // Only reached properly by clicking "Start" on the dashboard, which sets
    // this flag via navigate(..., { state: { fromDashboard: true } }). A
    // pasted/bookmarked/shared link, or a fresh tab, arrives with no state
    // at all — that's exactly how we tell the two apart, since router state
    // isn't part of the URL. (A page refresh keeps it, since the browser
    // preserves history state across a reload in the same tab — so an
    // in-progress flow surviving a refresh is expected, not a loophole.)
    const cameFromDashboard = !!location.state?.fromDashboard;

    useEffect(() => {
        if (!cameFromDashboard) {
            setLoading(false);
            return;
        }
        async function fetchQuiz() {
            try {
                const res = await fetch(`${API_BASE}/quizzes/${id}`, { headers: authHeaders() });
                const data = await res.json();
                if (!res.ok) {
                    setLoadError(data.error || 'Could not load this quiz.');
                } else {
                    setQuiz(data);
                }
            } catch {
                setLoadError('Could not reach the server.');
            } finally {
                setLoading(false);
            }
        }
        fetchQuiz();
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [id, cameFromDashboard]);

    function handleStart() {
        // Attempt fullscreen
        if (document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen().catch(console.error);
        }
        // Same flag, carried forward — QuizPage checks for this the same way.
        navigate(`/quiz/${id}/take`, { state: { fromInstructions: true } });
    }

    if (!cameFromDashboard) {
        return (
            <div className="instructions-container">
                <div className="instructions-card">
                    <h1>Quiz unavailable</h1>
                    <p>Quizzes can only be started from your dashboard — please open this quiz by clicking "Start" there.</p>
                    <button className="btn-back" onClick={() => navigate('/student')}>
                        &larr; Back to Dashboard
                    </button>
                </div>
            </div>
        );
    }

    if (loading) {
        return (
            <div className="instructions-container">
                <div className="instructions-card">
                    <h1>Loading quiz...</h1>
                </div>
            </div>
        );
    }

    if (loadError || !quiz) {
        return (
            <div className="instructions-container">
                <div className="instructions-card">
                    <h1>Quiz unavailable</h1>
                    <p>{loadError || 'This quiz could not be found.'}</p>
                    <button className="btn-back" onClick={() => navigate('/student')}>
                        &larr; Back to Dashboard
                    </button>
                </div>
            </div>
        );
    }

    return (
        <div className="instructions-container">
            <div className="instructions-card">
                <div className="instructions-eyebrow">Quiz Instructions</div>
                <h1>{quiz.title}</h1>

                <div className="quiz-meta">
                    <span className="meta-chip">
                        <FaBriefcase className="meta-chip-icon" /> {quiz.domain || 'General'}
                    </span>
                    <span className="meta-chip">
                        <FaClock className="meta-chip-icon" /> {quiz.durationMinutes || 15} min
                    </span>
                    <span className="meta-chip">
                        <FaQuestionCircle className="meta-chip-icon" /> {quiz.questions?.length || 0} question{(quiz.questions?.length || 0) !== 1 ? 's' : ''}
                    </span>
                    {typeof quiz.totalPoints === 'number' && (
                        <span className="meta-chip">
                            <FaTrophy className="meta-chip-icon" /> {quiz.totalPoints} point{quiz.totalPoints !== 1 ? 's' : ''}
                        </span>
                    )}
                </div>

                {formatScheduled(quiz.startAt) && (
                    <div className="quiz-schedule">
                        <FaCalendarAlt className="meta-chip-icon" />
                        <span>Available {formatScheduled(quiz.startAt)}{formatScheduled(quiz.endAt) ? ` – ${formatScheduled(quiz.endAt)}` : ''}</span>
                    </div>
                )}

                <div className="instructions-badge">
                    <FaExclamationTriangle /> Instructions
                </div>
                <ul className="instructions-list">
                    <li>Once started, <strong className="instr-warn">the timer cannot be paused</strong> — make sure you have {quiz.durationMinutes || 15} uninterrupted minutes.</li>
                    <li>The quiz will open in fullscreen mode. <strong className="instr-warn">Avoid switching tabs or exiting fullscreen.</strong></li>
                    <li>You can move between questions using Previous / Next before submitting.</li>
                    <li><strong className="instr-warn">Submitting is final</strong> — you won't be able to retake this quiz once it's finished.</li>
                    <li>Make sure you have a stable internet connection before starting.</li>
                </ul>

                <div className="instructions-actions">
                    <button className="btn-start-quiz" onClick={handleStart}>
                        Start Quiz
                    </button>
                </div>
            </div>
        </div>
    );
};

export default QuizInstructions;
</file>

<file path="client/src/component/QuizPage.css">
/* This is a full light-mode app screen, not a page that should follow a
   dark-mode default. Pin html/body/#root to this page's own background —
   otherwise, on a phone in dark mode with short content (e.g. a small
   system font shrinking everything), the browser fills the leftover space
   below the document using its own dark default instead of this CSS. */
html, body, #root {
    background: #f0f2f5;
    min-height: 100%;
    color-scheme: light;
}
#root {
    width: 100%;
    max-width: 100%;
    border-inline: none;
    display: block;
    text-align: initial;
}

.quiz-page-outer {
    min-height: 100vh;
    min-height: 100dvh;
    background-color: #f0f2f5;
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
}

/* --- Timer rings --- */
.quiz-timer-row {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 28px;
}

/* Each timer is now "Label :" text next to a ring that only shows the number */
.timer-unit {
    display: flex;
    align-items: center;
    gap: 10px;
}

.timer-unit-label {
    font-weight: 700;
    font-size: 0.95rem;
    color: #2d2d2d;
}

.timer-ring {
    position: relative;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
}

.timer-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.timer-ring-track {
    fill: #1b1b2f;
    stroke: #2b2b45;
    stroke-width: 4;
}

.timer-ring-progress {
    fill: none;
    stroke: #1dd1a1;
    stroke-width: 4;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear;
}

.timer-ring-center {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}

.timer-ring-value {
    color: #1dd1a1;
    font-weight: 800;
    font-size: 1.15rem;
    line-height: 1;
}

/* --- Card --- */
/* Fills the page like a proper full-screen quiz. The whole content block
   (timer, info, question/options, footer) is centered together as one
   unit via justify-content: center below — NOT top-anchored with the
   footer pinned to the very bottom via margin-top: auto. That approach
   looked fine with a lot of content, but with a single short question on
   a tall/wide screen it left a huge dead gap between the options and the
   Previous/Next buttons. Centering the group means the leftover space
   splits evenly above and below it instead of piling up in one spot —
   and pushing the footer up on its own (without centering the rest too)
   just relocates the same problem into a cramped top half. */
.quiz-card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e6e6e6;
    box-shadow: 0 20px 45px rgba(45, 45, 45, 0.06);
    padding: 44px 64px 56px;
    width: 100%;
    max-width: 1040px;
    min-height: calc(100vh - 80px);
    min-height: calc(100dvh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.quiz-info-box {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    background: #f7f7fb;
    border-radius: 12px;
    padding: 22px 30px;
    margin-bottom: 24px;
    font-size: 1.05rem;
}

.quiz-info-col p {
    margin: 0 0 10px 0;
    color: #2d2d2d;
    font-size: 1.05rem;
}

.quiz-info-col p:last-child { margin-bottom: 0; }

.quiz-info-col .label {
    font-weight: 700;
    color: #1f1f1f;
}

.quiz-progress {
    text-align: right;
    color: #999;
    font-size: 0.9rem;
    margin: 0 0 20px 0;
}

/* Holds the question + options. No longer flex/centered — it just sits
   naturally after the info box with normal spacing. The footer (outside
   this wrapper) is what anchors to the bottom of the full-height card.
   The margin-bottom here is a GUARANTEED minimum gap before the footer —
   .quiz-footer's margin-top:auto only pushes it down when the card has
   leftover space (e.g. a tall desktop card with a short question); with
   little/no leftover space (small font, short content) that auto-margin
   collapses to 0, and without this margin the footer buttons would sit
   flush against the last option. */
.quiz-body {
    display: flex;
    flex-direction: column;
    margin-bottom: 40px;
}

.quiz-question {
    text-align: top;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1f1f1f;
    margin: 0 0 36px 0;
    line-height: 1.4;
}

.options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 820px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
}

.option-btn {
    background: #fff;
    border: 1.5px solid #e4e4ee;
    border-radius: 10px;
    padding: 24px 26px;
    font-size: 1.05rem;
    color: #333;
    cursor: pointer;
    text-align: center;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
}

.option-btn:hover {
    border-color: #c9c3f7;
    background: #fbfaff;
}

.option-btn.selected {
    border-color: #6c5ce7;
    background: #6c5ce7;
    color: #fff;
    font-weight: 600;
}

/* Sits right after the question/options with the normal gap that
   .quiz-body's margin-bottom already guarantees — no longer pinned to the
   bottom of the card on its own, since the whole block is centered as a
   unit via .quiz-card's justify-content: center above. */
.quiz-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
}

.nav-btn {
    border: none;
    border-radius: 10px;
    padding: 14px 34px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
}

.nav-btn-secondary {
    background: #f0f0f5;
    color: #b3b3c0;
}

.nav-btn-secondary:disabled {
    cursor: not-allowed;
}

.nav-btn-secondary:not(:disabled) {
    color: #555;
    background: #ececf4;
}

.nav-btn-primary {
    background: #6c5ce7;
    color: #fff;
}

.nav-btn-primary:hover:not(:disabled) {
    background: #5a4bcf;
}

.nav-btn-primary:disabled {
    background: #d8d4f7;
    cursor: not-allowed;
}

.submit-error {
    color: #e74c3c;
    text-align: center;
    margin-top: 18px;
    font-size: 0.9rem;
}

@media (max-width: 768px) {
    .quiz-page-outer {
        padding: 20px 12px;
    }
    .quiz-card {
        padding: 28px 22px 36px;
        min-height: auto;
    }
    .quiz-body {
        margin-bottom: 28px;
    }
    .quiz-question {
        font-size: 1.15rem;
    }
    .options-grid {
        grid-template-columns: 1fr;
    }
    .quiz-info-box {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
        padding: 18px 20px;
    }
    .quiz-info-col {
        width: 100%;
        text-align: left;
    }
    .quiz-info-col p {
        margin: 0 0 6px 0;
    }
    .quiz-timer-row {
        gap: 18px;
    }
    .timer-unit-label {
        font-size: 0.8rem;
    }
}

/* --- Result popup: small box, auto-dismisses and redirects --- */
.quiz-result-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 30, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: resultFadeIn 0.2s ease;
}

.quiz-result-popup {
    background: #fff;
    border-radius: 16px;
    padding: 32px 48px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
    animation: resultPopIn 0.25s ease;
}

.quiz-result-score {
    font-size: 2.2rem;
    font-weight: 800;
    color: #6c5ce7;
}

.quiz-result-note {
    color: #888;
    font-size: 0.9rem;
    margin: 6px 0 0 0;
}

@keyframes resultFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes resultPopIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
}

/* --- Fullscreen enforcement --- */
/* When the student exits fullscreen, the quiz content blurs and becomes
   unusable — it can't be read, clicked, selected, or screenshotted cleanly —
   until they click back into fullscreen via the overlay below. */
.quiz-page-outer.is-blurred .quiz-card {
    filter: blur(6px);
    pointer-events: none;
    user-select: none;
}

.quiz-card {
    user-select: none;
}

.fullscreen-warning-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 30, 0.55);
    backdrop-filter: blur(2px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
}

.fullscreen-warning-box {
    background: #fff;
    border-radius: 16px;
    padding: 40px 44px;
    max-width: 420px;
    width: 90%;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
}

.fullscreen-warning-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: #fdecea;
    color: #e74c3c;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.4rem;
}

.fullscreen-warning-box h2 {
    margin: 0 0 10px 0;
    color: #1f1f1f;
    font-size: 1.15rem;
}

.fullscreen-warning-box p {
    margin: 0 0 24px 0;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
}
