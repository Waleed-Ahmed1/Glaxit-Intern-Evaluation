.charts-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 10px; }
.chart-card { background: #ffffff; padding: 20px; border-radius: 15px; border: 1px solid #e0e0e0; }
.chart-card h3 { font-size: 0.9rem; color: #555; margin-bottom: 15px; }

.data-table { background: white; padding: 20px; border-radius: 15px; border: 1px solid #f0f0f0; }
.table-scroll-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.9rem; }
th { color: #7f8c8d; font-weight: 600; text-align: left; padding: 15px; border-bottom: 2px solid #f4f4f4; }
td { padding: 15px; border-bottom: 1px solid #f4f4f4; color: #333; }
.btn-start { background: #00b894; color: white; border: none; padding: 8px 18px; border-radius: 6px; cursor: pointer; }
.btn-stop { background: #d63031; color: white; border: none; padding: 8px 18px; border-radius: 6px; cursor: not-allowed; opacity: 0.7; }

/* Card list shown only on phones (see the media query below) — each row of
   the table becomes its own card with label/value pairs stacked vertically,
   instead of a table row squeezed into a narrow screen. */
.record-cards { display: none; }
/* Table Layout Fix */
.data-table { 
    background: white; 
    padding: 20px; 
    border-radius: 15px; 
    border: 1px solid #e0e0e0; 
}

table { 
    width: 100%; 
    border-collapse: collapse; 
    margin-top: 10px; 
    font-size: 0.9rem;
    table-layout: fixed; /* This forces columns to distribute evenly */
}

th, td { 
    padding: 15px; 
